      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "sendlix",
    "newsletter",
    "mailing",
    "group",
    "subscribe",
