{
  "name": "@sendlix/group",
  "version": "1.0.0",
  "description": "Sendlix Group SDK – subscribe users to mailing groups with optional Proof-of-Work bot protection.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sendlix/group-subscription-sdk.git"
  },
  "exports": {
